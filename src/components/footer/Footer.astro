---
interface Links {
  spotify?: string;
  appleMusic?: string;
  youtube?: string;
  instagram?: string;
  soundcloud?: string;
  tiktok?: string;
}
interface Artist {
  name: string;
  areaCode: string;
  links: Links;
  footerHeadlineLines: string[];
  footerCopy: string;
  bookingHandle: string;
}

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;

type SocialLabel = "Spotify" | "Apple Music" | "YouTube" | "Instagram" | "SoundCloud" | "TikTok";
const socialEntries: { label: SocialLabel; key: keyof Links }[] = [
  { label: "Spotify", key: "spotify" },
  { label: "Apple Music", key: "appleMusic" },
  { label: "YouTube", key: "youtube" },
  { label: "Instagram", key: "instagram" },
  { label: "SoundCloud", key: "soundcloud" },
  { label: "TikTok", key: "tiktok" },
];
const socials = socialEntries
  .map((s) => ({ label: s.label, href: artist.links[s.key] }))
  .filter((s): s is { label: SocialLabel; href: string } => Boolean(s.href));

const lines = artist.footerHeadlineLines;
const year = new Date().getFullYear();

// Booking CTA — prefer Instagram DM if present, else just the handle
const bookingHref = artist.links.instagram ?? `https://www.instagram.com/${artist.bookingHandle}/`;
---

<footer id="links" class="border-t border-concrete/10 px-6 py-20 sm:px-10">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-24">
    <div class="lg:col-span-5">
      <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40">
        // outbound
      </div>
      <h2 class="font-display mt-6 text-[12vw] leading-[0.85] sm:text-[6vw] lg:text-[4vw]">
        {lines.slice(0, -1).map((l) => (
          <Fragment>{l}<br/></Fragment>
        ))}
        <span class="text-traffic">{lines[lines.length - 1]}</span>
      </h2>
      <p class="mt-8 max-w-md text-concrete/60">
        {artist.footerCopy}
      </p>
      <a
        href={bookingHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-3 border border-traffic bg-traffic/10 px-6 py-3 font-mono text-xs uppercase tracking-[0.3em] text-traffic transition-all hover:bg-traffic hover:text-asphalt"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-traffic" />
        Booking · DM @{artist.bookingHandle}
      </a>
    </div>

    <div class="lg:col-span-7">
      <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40">
        // channels
      </div>
      <ul class="mt-6 divide-y divide-concrete/10 border-y border-concrete/10">
        {socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-baseline justify-between py-5 transition-colors hover:text-traffic"
            >
              <span class="font-display text-2xl uppercase tracking-tight sm:text-3xl">
                {s.label}
              </span>
              <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/40 transition-colors group-hover:text-traffic">
                visit ↗
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar: legal + OBHOLZ SOLUTIONS branding -->
  <div class="mx-auto mt-20 max-w-7xl border-t border-concrete/10 pt-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="font-mono text-[10px] uppercase tracking-[0.4em] text-concrete/40">
          // built by
        </div>
        <a
          href="https://obholz-solutions.de"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex items-center gap-3 transition-opacity hover:opacity-70"
          aria-label="OBHOLZ SOLUTIONS"
        >
          <img
            src="/obholz-logo-white.svg"
            alt="OBHOLZ SOLUTIONS"
            width="48"
            height="48"
            class="h-12 w-12 opacity-90"
            loading="lazy"
          />
          <span class="font-display text-lg uppercase leading-none tracking-tight text-concrete sm:text-xl">
            OBHOLZ<br/>SOLUTIONS
          </span>
        </a>
        <p class="mt-3 max-w-xs font-mono text-[10px] uppercase tracking-[0.25em] text-concrete/40">
          Independent fan tribute. No affiliation with {artist.name} or his label.
        </p>
      </div>

      <div class="flex flex-col gap-3 text-right font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/50 sm:items-end">
        <div class="flex flex-wrap justify-end gap-x-6 gap-y-2">
          <a href="/artists" class="transition-colors hover:text-traffic">Roster</a>
          <a href="/impressum" class="transition-colors hover:text-traffic">Impressum</a>
          <a href="/datenschutz" class="transition-colors hover:text-traffic">Datenschutz</a>
        </div>
        <div class="text-concrete/40">© {year} {artist.name} · {artist.areaCode} — site © OBHOLZ SOLUTIONS</div>
      </div>
    </div>
  </div>
</footer>
