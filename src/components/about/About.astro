---
interface Album {
  title: string;
  year: number;
  type: string;
}
interface Release {
  title: string;
  feat?: string | null;
  year: number;
  type: string;
}
interface Track {
  title: string;
  feat?: string | null;
  streams: number;
  year?: number;
}
interface Stats {
  totalStreams: number;
  totalStreamsDisplay?: string;
  monthlyListeners: number;
  spotifyFollowers: number;
}
interface Artist {
  name: string;
  city: string;
  areaCode: string;
  aboutHeadlineLines: string[];
  bioParagraphs: string[];
  stats: Stats;
  topTracks: Track[];
  albums: Album[];
  recentReleases?: Release[];
}

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;

const totalStreamsDisplay =
  artist.stats.totalStreamsDisplay ??
  (artist.stats.totalStreams >= 1_000_000
    ? `${(artist.stats.totalStreams / 1_000_000).toFixed(1).replace(/\.0$/, "")}M+`
    : `${artist.stats.totalStreams.toLocaleString("en-GB")}`);

const stats = [
  { label: "Total streams", value: totalStreamsDisplay },
  { label: "Monthly listeners", value: artist.stats.monthlyListeners.toLocaleString("en-GB") },
  { label: "City", value: "1" },
  { label: "Area code", value: artist.areaCode },
];

const formatStreams = (n: number) => {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace(/\.0$/, "")}M`;
  if (n >= 1_000) return `${Math.round(n / 1_000)}k`;
  return String(n);
};

const lines = artist.aboutHeadlineLines;
---

<section id="about" class="relative border-t border-concrete/10 px-6 py-24 sm:px-10 sm:py-40">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-24">
    <div class="lg:col-span-5">
      <div class="sticky top-10">
        <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40">
          // 01 — about
        </div>
        <h2 class="font-display mt-6 text-[12vw] leading-[0.85] text-concrete sm:text-[7vw] lg:text-[5vw]">
          {lines.slice(0, -1).map((l, i) => (
            <Fragment>
              {l}{i < lines.length - 2 && <br/>}<br/>
            </Fragment>
          ))}
          <span class="text-traffic">{lines[lines.length - 1]}</span>.
        </h2>
        {artist.bioParagraphs.map((p, i) => (
          <p
            class:list={[
              "max-w-md text-base leading-relaxed text-concrete/70",
              i === 0 ? "mt-8" : "mt-4",
            ]}
            set:html={p}
          />
        ))}
      </div>
    </div>

    <div class="lg:col-span-7">
      <div class="grid grid-cols-2 gap-px bg-concrete/10">
        {stats.map((s) => (
          <div class="bg-asphalt p-6 sm:p-10">
            <div class="font-mono text-[10px] uppercase tracking-[0.4em] text-concrete/40">
              {s.label}
            </div>
            <div class="font-display mt-4 text-5xl text-concrete sm:text-7xl">
              {s.value}
            </div>
          </div>
        ))}
      </div>

      {artist.albums.length > 0 && (
        <div class="mt-16">
          <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40">
            // {artist.albums.length === 1 ? "album" : "albums"}
          </div>
          <ul class="mt-6 divide-y divide-concrete/10 border-y border-concrete/10">
            {artist.albums.map((a) => (
              <li class="flex items-baseline justify-between py-5">
                <span class="font-display text-2xl uppercase tracking-tight text-concrete sm:text-3xl">
                  {a.title}
                </span>
                <span class="font-mono text-xs text-concrete/40">{a.year} · {a.type}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {artist.recentReleases && artist.recentReleases.length > 0 && (
        <div class="mt-12">
          <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40">
            // recent drops
          </div>
          <ul class="mt-6 divide-y divide-concrete/10 border-y border-concrete/10">
            {artist.recentReleases.map((r) => (
              <li class="flex items-baseline justify-between py-3.5">
                <span class="font-display flex-1 text-lg uppercase tracking-tight text-concrete sm:text-xl">
                  {r.title}
                  {r.feat && (
                    <span class="ml-2 font-body text-xs lowercase tracking-normal text-concrete/40">
                      feat. {r.feat}
                    </span>
                  )}
                </span>
                <span class="font-mono text-xs text-concrete/40">{r.year} · {r.type}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="mt-16">
        <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40">
          // top tracks
        </div>
        <ol class="mt-6 space-y-3">
          {artist.topTracks.map((t, i) => (
            <li class="group flex items-baseline gap-4 border-b border-concrete/5 py-3 transition-colors hover:border-traffic/40">
              <span class="w-8 font-mono text-[11px] text-concrete/40">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="font-display flex-1 text-xl uppercase tracking-tight text-concrete transition-colors group-hover:text-traffic sm:text-2xl">
                {t.title}
                {t.feat && (
                  <span class="ml-2 font-body text-xs lowercase tracking-normal text-concrete/40">
                    feat. {t.feat}
                  </span>
                )}
              </span>
              <span class="font-mono text-[11px] text-concrete/40">
                {formatStreams(t.streams)}
              </span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>
