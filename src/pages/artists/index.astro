---
import Layout from "../../layouts/Layout.astro";
import ya from "../../content/ya.json";
import kav from "../../content/artists/kav.json";
import bailey from "../../content/artists/bailey-holmes.json";
import charlie from "../../content/artists/charlie-choppa.json";

const roster = [
  { ...ya, slug: "ya", url: "/", featured: true },
  { ...kav, url: "/artists/kav" },
  { ...bailey, url: "/artists/bailey-holmes" },
  { ...charlie, url: "/artists/charlie-choppa" },
];

const totalCombinedStreams = roster.reduce((sum, a) => sum + (a.stats.totalStreams || 0), 0);
const totalDisplay = (totalCombinedStreams / 1000000).toFixed(0) + "M+";
const year = new Date().getFullYear();
---

<Layout
  title="The Bradford Bassline Roster — YA-Music"
  description="The West Yorkshire bassline crew. YA, KAV, Bailey Holmes, Charlie Choppa — 60M+ streams between them."
  canonical="/artists"
>
  <main class="min-h-screen bg-asphalt">
    <!-- Header / hero -->
    <section class="relative border-b border-concrete/10 px-6 pt-20 pb-16 sm:px-10 sm:pt-32 sm:pb-24">
      <div class="pointer-events-none absolute inset-6 border border-concrete/10 sm:inset-10" />

      <div class="pointer-events-none absolute left-6 top-6 font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/40 sm:left-10 sm:top-10">
        The roster · West Yorkshire UK
      </div>
      <div class="pointer-events-none absolute right-6 top-6 flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/40 sm:right-10 sm:top-10">
        <span class="live-dot inline-block h-2 w-2 rounded-full bg-redbull" />
        {roster.length} artists · {totalDisplay} streams
      </div>

      <div class="mx-auto max-w-7xl">
        <div class="font-mono text-[11px] uppercase tracking-[0.4em] text-concrete/40 mt-8 sm:mt-12">
          // the crew
        </div>
        <h1 class="font-display mt-6 text-[16vw] leading-[0.85] text-concrete sm:text-[10vw] lg:text-[8vw]">
          Bradford<br/>
          <span class="text-traffic">bassline.</span>
        </h1>
        <p class="mt-8 max-w-xl text-base leading-relaxed text-concrete/70 sm:text-lg">
          The West Yorkshire bassline scene in one place. <strong class="text-concrete">YA</strong>,
          <strong class="text-concrete">KAV</strong>,
          <strong class="text-concrete">Bailey Holmes</strong> and
          <strong class="text-concrete">Charlie Choppa</strong> — four artists, one sound, {totalDisplay} streams.
        </p>
      </div>
    </section>

    <!-- Roster cards -->
    <section class="px-6 py-20 sm:px-10 sm:py-32">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-px bg-concrete/10 sm:grid-cols-2">
        {roster.map((artist) => {
          const cityShort = artist.city.split(",")[0];
          const totalDisp = artist.stats.totalStreamsDisplay
            || (artist.stats.totalStreams >= 1000000
              ? Math.round(artist.stats.totalStreams / 100000) / 10 + "M+"
              : artist.stats.totalStreams.toLocaleString("en-GB"));
          const topTrack = artist.topTracks[0];
          const poster = "videos" in artist && artist.videos && artist.videos[0]
            ? artist.videos[0].poster
            : null;
          return (
            <a
              href={artist.url}
              class="group relative block bg-asphalt p-8 transition-colors hover:bg-asphalt/40 sm:p-12"
            >
              {poster && (
                <div
                  class="absolute inset-0 bg-cover bg-center opacity-20 transition-opacity duration-500 group-hover:opacity-40"
                  style={`background-image: url(${poster});`}
                />
              )}
              <div
                class="absolute inset-0 transition-opacity duration-500"
                style="background: linear-gradient(180deg, rgba(10,10,10,0.5) 0%, rgba(10,10,10,0.85) 100%);"
              />
              <div class="relative z-10">
                <div class="flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/50">
                  <span>{cityShort} · {artist.areaCode}</span>
                  {artist.featured && <span class="text-traffic">Featured</span>}
                </div>
                <h2
                  class="font-display mt-6 text-[14vw] leading-[0.85] uppercase text-concrete transition-colors group-hover:text-traffic sm:text-[6vw] lg:text-[4.5vw]"
                  style="letter-spacing:-0.04em;"
                >
                  {artist.name}
                </h2>
                <p class="mt-4 max-w-xs text-sm text-concrete/60">{artist.tagline}</p>

                <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/50">
                  <span><span class="text-concrete">{totalDisp}</span> streams</span>
                  <span><span class="text-concrete">{artist.stats.monthlyListeners.toLocaleString("en-GB")}</span> monthly</span>
                  {topTrack && (
                    <span class="basis-full sm:basis-auto">
                      Top: <span class="text-concrete">{topTrack.title}</span>
                    </span>
                  )}
                </div>

                <div class="mt-10 inline-flex items-center gap-3 border border-concrete/30 px-5 py-2.5 font-mono text-[11px] uppercase tracking-[0.3em] text-concrete transition-all group-hover:border-traffic group-hover:text-traffic">
                  <span class="inline-block h-1.5 w-1.5 rounded-full bg-traffic" />
                  Open hub →
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-concrete/10 px-6 py-16 sm:px-10">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.4em] text-concrete/40">
              // built by
            </div>
            <a
              href="https://obholz-solutions.de"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-flex items-center gap-3 transition-opacity hover:opacity-70"
              aria-label="OBHOLZ SOLUTIONS"
            >
              <img src="/obholz-logo-white.svg" alt="OBHOLZ SOLUTIONS" width="48" height="48" class="h-12 w-12 opacity-90" loading="lazy" />
              <span class="font-display text-lg uppercase leading-none tracking-tight text-concrete sm:text-xl">
                OBHOLZ<br/>SOLUTIONS
              </span>
            </a>
            <p class="mt-3 max-w-xs font-mono text-[10px] uppercase tracking-[0.25em] text-concrete/40">
              Independent fan tribute. No affiliation with the artists or their labels.
            </p>
          </div>
          <div class="flex flex-col gap-3 text-right font-mono text-[10px] uppercase tracking-[0.3em] text-concrete/50 sm:items-end">
            <div class="flex flex-wrap justify-end gap-x-6 gap-y-2">
              <a href="/" class="transition-colors hover:text-traffic">YA Hub</a>
              <a href="/impressum" class="transition-colors hover:text-traffic">Impressum</a>
              <a href="/datenschutz" class="transition-colors hover:text-traffic">Datenschutz</a>
            </div>
            <div class="text-concrete/40">© {year} The roster — site © OBHOLZ SOLUTIONS</div>
          </div>
        </div>
      </div>
    </footer>
  </main>
</Layout>
