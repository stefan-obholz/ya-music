---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
}

const {
  title = "YA — 01274 / Bradford",
  description = "YA — Bradford rapper. 20M+ streams independent. The kid from 01274.",
  ogImage = "/og-image-v2.png",
  ogImageAlt = "YA — the kid from 01274. Bradford rapper, 20M+ streams.",
  canonical = Astro.url.pathname,
} = Astro.props;

const ORIGIN = "https://ya-music.com";
const ogImageAbs = ogImage.startsWith("http") ? ogImage : `${ORIGIN}${ogImage}`;
const canonicalAbs = canonical.startsWith("http") ? canonical : `${ORIGIN}${canonical}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalAbs} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="music.musician" />
    <meta property="og:url" content={canonicalAbs} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <title>{title}</title>
  </head>
  <body class="bg-asphalt text-concrete font-body">
    <slot />
  </body>
</html>
